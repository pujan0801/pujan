yle={{ marginBottom: \"2px\" }} /> Home\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                as={Link}\r\n                to=\"/about\"\r\n                onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiOutlineUser style={{ marginBottom: \"2px\" }} /> About\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                as={Link}\r\n                to=\"/project\"\r\n                onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiOutlineFundProjectionScreen\r\n                  style={{ marginBottom: \"2px\" }}\r\n                />{\" \"}\r\n                Projects\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                as={Link}\r\n                to=\"/resume\"\r\n                onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiFillBuild style={{ marginBottom: \"2px\" }} /> Experiences\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                  as={Link}\r\n                  to=\"/publications\"\r\n                  onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiFillAccountBook\r\n                    style={{ marginBottom: \"2px\" }}\r\n                />{\" \"}\r\n                Publications\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                  as={Link}\r\n                  to=\"/others\"\r\n                  onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiOutlineUser style={{ marginBottom: \"2px\" }} /> Others\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item className=\"fork-btn\">\r\n              <Button\r\n                href=\"https://drive.google.com/file/d/16n1RpLIcYKDzblfaKtyKfZgTg6dEIKC6/view?usp=share_link\"\r\n                target=\"_blank\"\r\n                className=\"fork-btn\"\r\n              >\r\n\r\n                <CgFileDocument style={{ fontSize: \"1.1em\" }} /> CV\r\n              </Button>\r\n            </Nav.Item>\r\n          </Nav>\r\n        </Navbar.Collapse>\r\n      </Container>\r\n    </Navbar>\r\n  );\r\n}\r\n\r\nexport default NavBar;\r\n","D:\\ps_res\\portfolio\\src\\components\\ScrollToTop.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Footer.js",["143"],[],"import React from \"react\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport {\n  AiFillGithub,\n  AiOutlineTwitter,\n  AiFillInstagram,\n} from \"react-icons/ai\";\nimport { FaLinkedinIn } from \"react-icons/fa\";\n\nfunction Footer() {\n  let date = new Date();\n  let year = date.getFullYear();\n  return (\n    <Container fluid className=\"footer\">\n      <Row>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Designed and Developed by Pujan Soni</h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Copyright © {year} PS </h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-body\">\n          <ul className=\"footer-icons\">\n            <li className=\"social-icons\">\n              <a\n                href=\"https://github.com/pujan2308\"\n                style={{ color: \"white\" }}\n                target=\"_blank\" \n                rel=\"noopener noreferrer\"\n              >\n                <AiFillGithub />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"https://www.linkedin.com/in/pujansoni\"\n                style={{ color: \"white\" }}\n                target=\"_blank\" \n                rel=\"noopener noreferrer\"\n              >\n                <FaLinkedinIn />\n              </a>\n    