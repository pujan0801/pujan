\Navbar.js",["139","140","141","142","143"],[],"import React, { useState } from \"react\";\r\nimport Navbar from \"react-bootstrap/Navbar\";\r\nimport Nav from \"react-bootstrap/Nav\";\r\nimport Container from \"react-bootstrap/Container\";\r\nimport logo from \"../Assets/logo.png\";\r\nimport Button from \"react-bootstrap/Button\";\r\nimport {Link, Route, Router} from \"react-router-dom\";\r\nimport {\r\n  AiOutlineHome,\r\n  AiOutlineFundProjectionScreen,\r\n  AiOutlineUser,\r\n    AiFillAccountBook,\r\n    AiFillBuild\r\n} from \"react-icons/ai\";\r\n\r\nimport { CgFileDocument } from \"react-icons/cg\";\r\nimport Home from \"./Home/Home\";\r\n\r\nfunction NavBar() {\r\n  const [expand, updateExpanded] = useState(false);\r\n  const [navColour, updateNavbar] = useState(false);\r\n  const [dropdown, setDropdown] = useState(false);\r\n\r\n  function scrollHandler() {\r\n    if (window.scrollY >= 20) {\r\n      updateNavbar(true);\r\n    } else {\r\n      updateNavbar(false);\r\n    }\r\n  }\r\n\r\n  window.addEventListener(\"scroll\", scrollHandler);\r\n\r\n  return (\r\n    <Navbar\r\n      expanded={expand}\r\n      fixed=\"top\"\r\n      expand=\"md\"\r\n      className={navColour ? \"sticky\" : \"navbar\"}\r\n    >\r\n      <Container>\r\n        <Navbar.Brand href=\"/\" className=\"d-flex\">\r\n          <img src={logo} className=\"img-fluid logo\" alt=\"brand\"/>\r\n        </Navbar.Brand>\r\n        <Navbar.Toggle\r\n          aria-controls=\"responsive-navbar-nav\"\r\n          onClick={() => {\r\n            updateExpanded(expand ? false : \"expanded\");\r\n          }}\r\n        >\r\n          <span></span>\r\n          <span></span>\r\n          <span></span>\r\n        </Navbar.Toggle>\r\n        <Navbar.Collapse id=\"responsive-navbar-nav\">\r\n          <Nav className=\"ms-auto\" defaultActiveKey=\"#home\">\r\n            <Nav.Item>\r\n              <Nav.Link as={Link} to=\"/\" onClick={() => updateExpanded(false)}>\r\n                <AiOutlineHome style={{ marginBottom: \"2px\" }} /> Home\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                as={Link}\r\n                to=\"/about\"\r\n                onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiOutlineUser style={{ marginBottom: \"2px\" }} /> About\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                as={Link}\r\n                to=\"/project\"\r\n                onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiOutlineFundProjectionScreen\r\n                  style={{ marginBottom: \"2px\" }}\r\n                />{\" \"}\r\n                Projects\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                as={Link}\r\n                to=\"/resume\"\r\n                onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiFillBuild style={{ marginBottom: \"2px\" }} /> Experiences\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                  as={Link}\r\n                  to=\"/publications\"\r\n                  onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiFillAccountBook\r\n                    style={{ marginBottom: \"2px\" }}\r\n                />{\" \"}\r\n                Publications\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item>\r\n              <Nav.Link\r\n                  as={Link}\r\n                  to=\"/others\"\r\n                  onClick={() => updateExpanded(false)}\r\n              >\r\n                <AiOutlineUser style={{ marginBottom: \"2px\" }} /> Others\r\n              </Nav.Link>\r\n            </Nav.Item>\r\n\r\n            <Nav.Item className=\"fork-btn\">\r\n              <Button\r\n                href=\"https://drive.google.com/file/d/16n1RpLIcYKDzblfaKtyKfZgTg6dEIKC6/view?usp=share_link\"\r\n                target=\"_blank\"\r\n                className=\"fork-btn\"\r\n              >\r\n\r\n                <CgFileDocument style={{ fontSize: \"1.1em\" }} /> CV\r\n              </Button>\r\n            </Nav.Item>\r\n          </Nav>\r\n        </Navbar.Collapse>\r\n      </Container>\r\n    </Navbar>\r\n  );\r\n}\r\n\r\nexport default NavBar;\r\n","D:\\ps_res\\portfolio\\src\\components\\ScrollToTop.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Footer.js",["144"],[],"import React from \"react\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport {\n  AiFillGithub,\n  AiOutlineTwitter,\n  AiFillInstagram,\n} from \"react-icons/ai\";\nimport { FaLinkedinIn } from \"react-icons/fa\";\n\nfunction Footer() {\n  let date = new Date();\n  let year = date.getFullYear();\n  return (\n    <Container fluid className=\"footer\">\n      <Row>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Designed and Developed by Pujan Soni</h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-copywright\">\n          <h3>Copyright © {year} PS </h3>\n        </Col>\n        <Col md=\"4\" className=\"footer-body\">\n          <ul className=\"footer-icons\">\n            <li className=\"social-icons\">\n              <a\n                href=\"https://github.com/pujan2308\"\n                style={{ color: \"white\" }}\n                target=\"_blank\" \n                rel=\"noopener noreferrer\"\n              >\n                <AiFillGithub />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"https://www.linkedin.com/in/pujansoni\"\n                style={{ color: \"white\" }}\n                target=\"_blank\" \n                rel=\"noopener noreferrer\"\n              >\n                <FaLinkedinIn />\n              </a>\n            </li>\n            <li className=\"social-icons\">\n              <a\n                href=\"https://www.instagram.com/poojan.2308\"\n                style={{ color: \"white\" }}\n                target=\"_blank\" \n                rel=\"noopener noreferrer\"\n              >\n                <AiFillInstagram />\n              </a>\n            </li>\n          </ul>\n        </Col>\n      </Row>\n    </Container>\n  );\n}\n\nexport default Footer;\n","D:\\ps_res\\portfolio\\src\\components\\About\\About.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Publications\\Publications.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Experiences\\Experiences.js",["145","146"],[],"import React, { useState, useEffect } from \"react\";\nimport {Col, Container, Row} from \"react-bootstrap\";\nimport Particle from \"../Particle\";\nimport \"react-pdf/dist/esm/Page/AnnotationLayer.css\";\nimport expImg from \"../../Assets/exp.png\";\nimport ExpCard from \"./ExpCard\";\n\nfunction Experiences() {\n  return (\n      <Container fluid className=\"about-section\">\n        <Particle />\n        <Container>\n          <Row style={{ justifyContent: \"center\", padding: \"10px\" }}>\n            <Col\n                md={7}\n                style={{\n                  justifyContent: \"center\",\n                  paddingTop: \"30px\",\n                  paddingBottom: \"50px\",\n                }}\n            >\n              <h1 style={{ fontSize: \"2.1em\", paddingBottom: \"20px\" }}>\n                Work <strong className=\"purple\">Experiences</strong>\n              </h1>\n              <ExpCard />\n            </Col>\n            <Col\n                md={5}\n                style={{ paddingTop: \"120px\", paddingBottom: \"50px\" }}\n                className=\"about-img\"\n            >\n              <img src={expImg} alt=\"about\" className=\"img-fluid\" style={{ maxHeight: \"380px\" }} />\n            </Col>\n          </Row>\n\n        </Container>\n      </Container>\n  );\n}\nexport default Experiences;\n","D:\\ps_res\\portfolio\\src\\components\\Projects\\Projects.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Others\\Others.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Particle.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\About\\AboutCard.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Home\\Type.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\About\\EduCard.js",["147"],[],"import React, {useLayoutEffect} from \"react\";\r\nimport Card from \"react-bootstrap/Card\";\r\nimport { ImPointRight } from \"react-icons/im\";\r\n\r\nfunction EduCard() {\r\n    return (\r\n        <Card className=\"quote-card-view\">\r\n            <Card.Body>\r\n                <blockquote className=\"blockquote mb-0\">\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                        <span className=\"purple\" style={{fontSize: \"1.4em\"}}>GSFC University</span> <br/>\r\n                        <i>\r\n                            <b style={{fontSize: \"0.8em\"}}> August 2019 - present </b>\r\n                        </i>\r\n                    </p>\r\n                        <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                            <ImPointRight /> Cumulative Grade Point Average: 7.5\r\n                        </li>\r\n                        <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                            <ImPointRight /> Student Coordinator–Code ClubMember, GSFC University Innovation & Incubation Center for Applied Research (GUIITAR)\r\n                        </li>\r\n                        <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                            <ImPointRight /> Committee Member – TechNext (February 2020 – March 2020)\r\n                        </li> <br/>\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                    <span className=\"purple\" style={{fontSize: \"1.4em\"}}>Edu-Nova Higher Secondary School</span> <br/>\r\n                    <i>\r\n                        <b style={{fontSize: \"0.8em\"}}> April 2016 - March 2019 </b>\r\n                    </i>\r\n                        </p>\r\n                <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                    <ImPointRight /> Acquired the seat in JEE Quota after successfully clearing the  competitive exam-JEE Mains 2019.\r\n                    </li> <br/>\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                        <span className=\"purple\" style={{fontSize: \"1.4em\"}}>Bright Day School</span> <br/>\r\n                        <i>\r\n                            <b style={{fontSize: \"0.8em\"}}> April 2006 - April 2016 </b>\r\n                        </i>\r\n                    </p>\r\n                    <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                        <ImPointRight /> Studied throughout in Central Board with various in-house activities.\r\n                    </li>\r\n\r\n\r\n\r\n                </blockquote>\r\n            </Card.Body>\r\n        </Card>\r\n    );\r\n}\r\n\r\nexport default EduCard;\r\n","D:\\ps_res\\portfolio\\src\\components\\Home\\Home2.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Experiences\\ExpCard.js",["148","149","150","151","152","153"],[],"import React, {useLayoutEffect} from \"react\";\r\nimport Card from \"react-bootstrap/Card\";\r\n\r\nfunction ExpCard() {\r\n    return (\r\n        <Card className=\"quote-card-view\">\r\n            <Card.Body>\r\n                <blockquote className=\"blockquote mb-0\">\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                        <span className=\"purple\" style={{fontSize: \"1.4em\"}}>Experts Hub, Bangalore, Karnataka</span> <br/>\r\n                        <i>\r\n                            <b style={{fontSize: \"0.8em\", color: \"#E5A5FC\"}}> Intern </b> <br/>\r\n                            <b style={{fontSize: \"0.8em\"}}> June 2019 - July 2019 </b>\r\n                        </i>\r\n                    </p>\r\n                    <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                        There was an 8 days long internship program on <span style={{color: \"#E5A5FC\"}}>Machine Learning and Artificial Intelligence</span> tools and technologies and worked on a real time Machine/Deep learning based project under the aegis of Expertshub Industry.\r\n                        <div>\r\n                            <br/>\r\n                            <a href=\"https://drive.google.com/file/d/1fRM4-swrq-bZqgEzCxqVsB2nnXQCTTFZ/view?usp=share_link\" target=\"_blank\">\r\n                                <button className=\"btn-primary\">Certification</button>\r\n                            </a>\r\n                        </div>\r\n\r\n                    </li> <br/>\r\n\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                        <span className=\"purple\" style={{fontSize: \"1.4em\"}}>Experts Hub, Bangalore, Karnataka</span> <br/>\r\n                        <i>\r\n                            <b style={{fontSize: \"0.8em\", color: \"#E5A5FC\"}}> Intern </b> <br/>\r\n                            <b style={{fontSize: \"0.8em\"}}> July 2019 - July 2019 </b>\r\n                        </i>\r\n                    </p>\r\n                    <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                        There was an 8 days long internship program on various <span style={{color: \"#E5A5FC\"}}>Internet of Things </span> tools and technologies and worked on real time IoT application based projects under the aegis of Expertshub Industry.\r\n                        <div>\r\n                            <br/>\r\n                            <a href=\"https://drive.google.com/file/d/1FKkg3meBrz_pDcgfDYjqqCe9wSGigrYj/view?usp=share_link\" target=\"_blank\">\r\n                                <button className=\"btn-primary\">Certification</button>\r\n                            </a>\r\n                        </div>\r\n\r\n                    </li> <br/>\r\n\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                        <span className=\"purple\" style={{fontSize: \"1.4em\"}}>Rainbow Secure, New York, USA</span> <br/>\r\n                        <i>\r\n                            <b style={{fontSize: \"0.8em\", color: \"#E5A5FC\"}}> Speaker, Volunteer, Moderator </b> <br/>\r\n                            <b style={{fontSize: \"0.8em\"}}> October 2021 - November 2021 </b>\r\n                        </i>\r\n                    </p>\r\n                    <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                        I volunteered for the entire Cyber Symposium, which lasted a month. Managed the online crowd in the event and resolved queries and provided support. Provided Expert talk session on topic <span style={{color: \"#E5A5FC\"}}>Robotic Process Automation using Machine Learning</span>. Moderated minor talk events and interacted with the speakers as well as the audience.\r\n                        <div>\r\n                            <br/>\r\n                            <a href=\"https://drive.google.com/file/d/199ixAAUJKM8K9X6jMbwIag3UJGC0JwPn/view?usp=share_link\" target=\"_blank\">\r\n                                <button className=\"btn-primary\">Certification</button>\r\n                            </a>\r\n                        </div>\r\n\r\n                    </li> <br/>\r\n\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                        <span className=\"purple\" style={{fontSize: \"1.4em\"}}>Gurukula, Tntra Ecosystem, Vadodara</span> <br/>\r\n                        <i>\r\n                            <b style={{fontSize: \"0.8em\", color: \"#E5A5FC\"}}>Full Stack Intern </b> <br/>\r\n                            <b style={{fontSize: \"0.8em\"}}> June 2022 - July 2022 </b>\r\n                        </i>\r\n                    </p>\r\n                    <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                        Became proficient on industry level web applications and got acquainted\r\n                        with the process flow of a project in a Service provider organization.\r\n                        Discovered several tools and technologies used in advanced dynamic web\r\n                        applications and completed certain tasks in each of them to acquire skill in the domain.\r\n\r\n                        <div>\r\n                            <br/>\r\n                            <a href=\"https://drive.google.com/file/d/1PEtFadIJLJgAhK3OAHIgDw5-Mhy-RORQ/view?usp=share_link\" target=\"_blank\">\r\n                                <button className=\"btn-primary\">Certification</button>\r\n                            </a>\r\n                        </div>\r\n\r\n                    </li> <br/>\r\n\r\n                    <p style={{textAlign:(\"left\")}}>\r\n                        <span className=\"purple\" style={{fontSize: \"1.4em\"}}>Gurukula, Tntra Ecosystem, Vadodara</span> <br/>\r\n                        <i>\r\n                            <b style={{fontSize: \"0.8em\", color: \"#E5A5FC\"}}>Multi Domain Intern </b> <br/>\r\n                            <b style={{fontSize: \"0.8em\"}}> September 2022 - present </b>\r\n                        </i>\r\n                    </p>\r\n                    <li className=\"about-activity\" style={{fontSize: \"0.8em\"}}>\r\n                        Beginning with web development, a project was chosen to work on in a team of three\r\n                        throughout the internship period under the guidance of senior developers. Also\r\n                        Data Science, IoT and Industry Revolution, Internet 4.0, Cyber Security, and\r\n                        Cloud Computing were taught by the respective experts from inside as well as outside\r\n                        the organisation within the Gurukula Ecosystem. Likewise, case studies of flagship\r\n                        projects in each domain were developed.\r\n                        <div>\r\n                            <br/>\r\n                            <a href=\"https://drive.google.com/file/d/1NmsWx55RQ1sdbZNlt61Un2CufV7hnoCK/view?usp=sharing\" target=\"_blank\">\r\n                                <button className=\"btn-primary\">Certification</button>\r\n                            </a>\r\n                        </div>\r\n                    </li>\r\n                </blockquote>\r\n            </Card.Body>\r\n        </Card>\r\n    );\r\n}\r\n\r\nexport default ExpCard;\r\n","D:\\ps_res\\portfolio\\src\\components\\Publications\\PublicationCards.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Projects\\ProjectCards.js",[],[],"D:\\ps_res\\portfolio\\src\\components\\Others\\Certificates.js",["154","155","156","157","158"],[],"import React from \"react\";\r\nimport Card from \"react-bootstrap/Card\";\r\nimport { ImPointRight } from \"react-icons/im\";\r\n\r\nfunction Certificates() {\r\n    return (\r\n        <Card className=\"quote-card-view\">\r\n            <Card.Body>\r\n                <blockquote className=\"blockquote mb-0\">\r\n                    <ul>\r\n                        <li className=\"about-activity\">\r\n                            <ImPointRight />  <strong style={{fontSize:\"28px\"}} className=\"purple\">Technical</strong><strong style={{fontSize:\"28px\"}}> Events </strong>\r\n                            <div>\r\n                                <br/>\r\n                                <a href=\"https://drive.google.com/drive/folders/15piP_vFUri9L13MZiIquMDr53hP41vQ_?usp=share_link\" target=\"_blank\">\r\n                                    <button className=\"btn-primary\">Certifications</button>\r\n                                </a>\r\n                            </div>\r\n                        </li><br/>\r\n\r\